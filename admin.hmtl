<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Blaze.in | Admin Panel</title>
  
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/react@18/umd/react.production.min.js" crossorigin></script>
  <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js" crossorigin></script>
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
</head>
<body>
  <div id="root"></div>

  <script type="text/babel" data-type="module">
    import { initializeApp } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js";
    import { getAuth, signInAnonymously, signInWithCustomToken, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js";
    import { getDatabase, ref, onValue, push, update, remove } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-database.js";

    const { useState, useEffect } = React;

    const isLocalEnv = typeof __firebase_config === 'undefined';
    const firebaseConfig = !isLocalEnv ? JSON.parse(__firebase_config) : {
      apiKey: "AIzaSyDYrF3hwhJiAX0uBXam5zPaCfGRerAaxLs",
      authDomain: "blazejewellery-in.firebaseapp.com",
      databaseURL: "https://blazejewellery-in-default-rtdb.asia-southeast1.firebasedatabase.app",
      projectId: "blazejewellery-in",
      storageBucket: "blazejewellery-in.firebasestorage.app",
      messagingSenderId: "1431066860",
      appId: "1:1431066860:web:68b9ae2f264e305a82adc9",
      measurementId: "G-QZC8WT36NL"
    };
    
    const app = initializeApp(firebaseConfig);
    const auth = getAuth(app);
    const db = getDatabase(app);
    const appId = typeof __app_id !== 'undefined' ? __app_id : 'blaze-app-default';
    const safeAppId = typeof appId === 'string' ? appId.replace(/[.#$\[\]]/g, '_') : 'default_app_id';

    const PRODUCTS_PATH = isLocalEnv ? 'products' : `artifacts/${safeAppId}/public/data/products`;
    const ORDERS_PATH = isLocalEnv ? 'orders' : `artifacts/${safeAppId}/public/data/orders`;

    // --- ICONS ---
    const IconPlus = () => <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>;
    const IconEdit = () => <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"></path></svg>;
    const IconTrash = () => <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>;
    const IconTrending = () => <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline><polyline points="17 6 23 6 23 12"></polyline></svg>;
    const IconPackage = () => <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><line x1="16.5" y1="9.4" x2="7.5" y2="4.21"></line><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>;
    const IconClock = () => <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>;
    const IconWhatsApp = () => <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>;
    const IconMail = () => <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>;

    const formatPrice = (price) => `₹${Number(price).toLocaleString('en-IN')}`;

    const ProductManager = ({ products }) => {
      const [isAdding, setIsAdding] = useState(false);
      const [editingId, setEditingId] = useState(null);
      // Added Category field
      const [form, setForm] = useState({ name: '', category: 'Earrings', material: '', price: '', salePrice: '', stock: '', badge: '', image: '', isSale: false });
      const [isUploading, setIsUploading] = useState(false);

      const CLOUDINARY_CLOUD_NAME = "dg3osffxz"; 
      const CLOUDINARY_UPLOAD_PRESET = "blazejewellery.in"; 
      const CLOUDINARY_URL = `https://api.cloudinary.com/v1_1/${CLOUDINARY_CLOUD_NAME}/image/upload`;

      const handleImageUpload = async (e) => {
        const file = e.target.files[0];
        if (!file) return;
        setIsUploading(true);
        const formData = new FormData();
        formData.append('file', file);
        formData.append('upload_preset', CLOUDINARY_UPLOAD_PRESET);
        try {
          const res = await fetch(CLOUDINARY_URL, { method: 'POST', body: formData });
          const data = await res.json();
          if (data.secure_url) setForm({ ...form, image: data.secure_url });
          else alert("Upload failed. Verify Cloudinary Cloud Name & Preset.");
        } catch (err) { alert("Error uploading image."); } finally { setIsUploading(false); }
      };

      const handleSave = async (e) => {
        e.preventDefault();
        const payload = { ...form, price: Number(form.price), salePrice: Number(form.salePrice || form.price), stock: Number(form.stock), createdAt: Date.now() };
        try {
          if (editingId) await update(ref(db, `${PRODUCTS_PATH}/${editingId}`), payload);
          else await push(ref(db, PRODUCTS_PATH), payload);
          setIsAdding(false); setEditingId(null);
          setForm({ name: '', category: 'Earrings', material: '', price: '', salePrice: '', stock: '', badge: '', image: '', isSale: false });
        } catch (err) { alert("Error saving product!"); }
      };

      const handleDelete = async (id) => { if(window.confirm("Are you sure?")) await remove(ref(db, `${PRODUCTS_PATH}/${id}`)); };
      const openEdit = (p) => { setForm(p); setEditingId(p.id); setIsAdding(true); };

      if (isAdding) {
        return (
          <div className="bg-white p-6 rounded shadow">
            <h2 className="text-xl font-bold mb-6">{editingId ? 'Edit Product' : 'Add New Product'}</h2>
            <form onSubmit={handleSave} className="space-y-4">
              <div className="grid grid-cols-2 gap-4">
                <div>
                  <label className="block text-sm font-medium">Product Name</label>
                  <input type="text" required value={form.name} onChange={e => setForm({...form, name: e.target.value})} className="mt-1 block w-full border rounded p-2" />
                </div>
                <div>
                  <label className="block text-sm font-medium">Category</label>
                  <select value={form.category} onChange={e => setForm({...form, category: e.target.value})} className="mt-1 block w-full border rounded p-2 bg-white">
                    <option value="Earrings">Earrings</option>
                    <option value="Necklaces">Necklaces</option>
                    <option value="Rings">Rings</option>
                    <option value="Bracelets">Bracelets</option>
                    <option value="Other">Other</option>
                  </select>
                </div>
                <div>
                  <label className="block text-sm font-medium">Material</label>
                  <input type="text" value={form.material} onChange={e => setForm({...form, material: e.target.value})} className="mt-1 block w-full border rounded p-2" />
                </div>
                <div>
                  <label className="block text-sm font-medium">Stock Quantity</label>
                  <input type="number" required value={form.stock} onChange={e => setForm({...form, stock: e.target.value})} className="mt-1 block w-full border rounded p-2" />
                </div>
                <div>
                  <label className="block text-sm font-medium">Regular Price (₹)</label>
                  <input type="number" required value={form.price} onChange={e => setForm({...form, price: e.target.value})} className="mt-1 block w-full border rounded p-2" />
                </div>
                <div>
                  <label className="block text-sm font-medium">Sale Price (₹)</label>
                  <input type="number" value={form.salePrice} onChange={e => setForm({...form, salePrice: e.target.value})} className="mt-1 block w-full border rounded p-2" />
                </div>
                <div>
                  <label className="block text-sm font-medium">Badge (Optional e.g. NEW)</label>
                  <input type="text" value={form.badge} onChange={e => setForm({...form, badge: e.target.value})} className="mt-1 block w-full border rounded p-2" />
                </div>
                <div className="col-span-2">
                  <label className="block text-sm font-medium">Product Image (Cloudinary Upload)</label>
                  <div className="mt-1 flex items-center space-x-4 border p-4 rounded border-dashed bg-gray-50">
                    <input type="file" accept="image/*" onChange={handleImageUpload} disabled={isUploading} className="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded file:border-0 file:text-sm file:font-semibold file:bg-black file:text-white" />
                    {isUploading && <span className="text-sm text-blue-600 font-bold">Uploading...</span>}
                  </div>
                  {form.image && (
                    <div className="mt-4 relative inline-block">
                      <img src={form.image} alt="Preview" className="h-32 object-contain border bg-white p-2" />
                      <button type="button" onClick={() => setForm({...form, image: ''})} className="absolute -top-2 -right-2 bg-red-500 text-white rounded-full w-6 h-6 flex items-center justify-center text-xs">X</button>
                    </div>
                  )}
                </div>
                <div className="col-span-2 flex items-center mt-2">
                  <input type="checkbox" checked={form.isSale} onChange={e => setForm({...form, isSale: e.target.checked})} className="mr-2 h-4 w-4" />
                  <label className="text-sm font-bold text-red-600">Run Sale (Shows discounted price on store)</label>
                </div>
              </div>
              <div className="flex space-x-4 mt-6">
                <button type="submit" className="bg-black text-white px-6 py-2 rounded">Save Product</button>
                <button type="button" onClick={() => setIsAdding(false)} className="bg-gray-200 px-6 py-2 rounded">Cancel</button>
              </div>
            </form>
          </div>
        );
      }

      return (
        <div>
          <div className="flex justify-between items-center mb-6">
            <h2 className="text-2xl font-bold">Inventory</h2>
            <button onClick={() => { setForm({ name: '', category: 'Earrings', material: '', price: '', salePrice: '', stock: '', badge: '', image: '', isSale: false }); setEditingId(null); setIsAdding(true); }} className="bg-black text-white px-4 py-2 rounded flex items-center"><span className="mr-2"><IconPlus /></span> Add Product</button>
          </div>
          <div className="bg-white rounded shadow overflow-hidden">
            <table className="min-w-full divide-y divide-gray-200">
              <thead className="bg-gray-50">
                <tr>
                  <th className="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Product</th>
                  <th className="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Category</th>
                  <th className="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Price</th>
                  <th className="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Stock</th>
                  <th className="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
                </tr>
              </thead>
              <tbody className="bg-white divide-y divide-gray-200">
                {products.map(p => (
                  <tr key={p.id}>
                    <td className="px-6 py-4 flex items-center">
                      <img src={p.image} className="w-10 h-10 object-cover rounded mr-3 bg-gray-100" />
                      <div>
                        <div className="text-sm font-medium">{p.name}</div>
                        {p.isSale && <span className="text-[10px] text-red-600 font-bold">SALE</span>}
                      </div>
                    </td>
                    <td className="px-6 py-4 text-sm text-gray-500">{p.category || 'N/A'}</td>
                    <td className="px-6 py-4 text-sm">{p.isSale ? <span className="text-red-600 font-bold">{formatPrice(p.salePrice)}</span> : formatPrice(p.price)}</td>
                    <td className="px-6 py-4 text-sm">{p.stock} units</td>
                    <td className="px-6 py-4 text-sm flex space-x-3">
                      <button onClick={() => openEdit(p)} className="text-blue-600"><IconEdit /></button>
                      <button onClick={() => handleDelete(p.id)} className="text-red-600"><IconTrash /></button>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      );
    };

    const OrderManager = ({ orders }) => {
      const updateOrderStatus = async (id, status) => await update(ref(db, `${ORDERS_PATH}/${id}`), { status });
      const updateTracking = async (id, trackingNumber) => {
        await update(ref(db, `${ORDERS_PATH}/${id}`), { trackingNumber });
        alert("Tracking number saved!");
      };

      const notifyWhatsApp = (order) => {
        let msg = `Hi ${order.name},\nYour order from Blaze.in has been *${order.status}*!\n\nOrder Value: ${formatPrice(order.total)}`;
        if (order.trackingNumber) msg += `\nTracking Number/Link: ${order.trackingNumber}`;
        window.open(`https://wa.me/${order.phone.replace(/[^0-9]/g, '')}?text=${encodeURIComponent(msg)}`, '_blank');
      };

      const notifyEmail = (order) => {
        let subject = `Blaze.in Order Update - ${order.status}`;
        let body = `Hi ${order.name},\n\nYour order is ${order.status}.\nValue: ${formatPrice(order.total)}\nTracking: ${order.trackingNumber || 'N/A'}`;
        window.open(`mailto:${order.email}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`);
      };

      return (
        <div>
          <h2 className="text-2xl font-bold mb-6">Customer Orders</h2>
          <div className="space-y-6">
            {orders.length === 0 && <p className="text-gray-500">No orders yet.</p>}
            {orders.map(order => (
              <div key={order.id} className="bg-white rounded shadow p-6">
                <div className="flex justify-between mb-4 border-b pb-4">
                  <div>
                    <h3 className="font-bold">{order.name}</h3>
                    <p className="text-sm text-gray-500">{order.email} • {order.phone}</p>
                  </div>
                  <div className="text-right">
                    <span className="inline-block px-2 py-1 bg-gray-100 rounded text-xs font-bold uppercase mb-2">{order.status}</span>
                    <div className="font-bold text-xl">{formatPrice(order.total)}</div>
                  </div>
                </div>
                <div className="grid grid-cols-2 gap-6">
                  <div>
                    <h4 className="text-xs font-bold uppercase text-gray-500 mb-2">Items</h4>
                    <ul className="text-sm">{order.items.map((item, i) => <li key={i}>{item.qty}x {item.name}</li>)}</ul>
                    <p className="text-sm mt-4 text-gray-700">{order.address}</p>
                  </div>
                  <div className="bg-gray-50 p-4 border rounded">
                    <select value={order.status} onChange={(e) => updateOrderStatus(order.id, e.target.value)} className="border p-2 w-full text-sm mb-4">
                      <option value="Pending">Pending</option>
                      <option value="Shipped">Shipped</option>
                      <option value="Delivered">Delivered</option>
                    </select>
                    <div className="flex mb-4">
                      <input type="text" placeholder="Tracking ID/URL" defaultValue={order.trackingNumber} className="border p-2 text-sm w-full" id={`track-${order.id}`} />
                      <button onClick={() => updateTracking(order.id, document.getElementById(`track-${order.id}`).value)} className="bg-black text-white px-3 text-sm">Save</button>
                    </div>
                    <div className="flex space-x-2 pt-2 border-t">
                      <button onClick={() => notifyWhatsApp(order)} className="flex-1 flex items-center justify-center bg-[#25D366] text-white py-2 rounded text-xs font-bold uppercase"><span className="mr-1"><IconWhatsApp /></span> WhatsApp</button>
                      <button onClick={() => notifyEmail(order)} className="flex-1 flex items-center justify-center bg-blue-600 text-white py-2 rounded text-xs font-bold uppercase"><span className="mr-1"><IconMail /></span> Email</button>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      );
    };

    function App() {
      const [user, setUser] = useState(null);
      const [adminAuth, setAdminAuth] = useState(false);
      const [products, setProducts] = useState([]);
      const [orders, setOrders] = useState([]);
      const [tab, setTab] = useState('dashboard');

      useEffect(() => {
        const initAuth = async () => {
          try {
            if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
              await signInWithCustomToken(auth, __initial_auth_token);
            } else {
              await signInAnonymously(auth);
            }
          } catch (err) {
            console.error(err);
          }
        };
        initAuth();
        return onAuthStateChanged(auth, setUser);
      }, []);

      useEffect(() => {
        if (!user) return;
        
        const productsRef = ref(db, PRODUCTS_PATH);
        const unsubProducts = onValue(productsRef, (snapshot) => {
          const data = snapshot.val();
          const p = data ? Object.keys(data).map(key => ({ id: key, ...data[key] })) : [];
          setProducts(p.sort((a, b) => b.createdAt - a.createdAt));
        });

        const ordersRef = ref(db, ORDERS_PATH);
        const unsubOrders = onValue(ordersRef, (snapshot) => {
          const data = snapshot.val();
          const o = data ? Object.keys(data).map(key => ({ id: key, ...data[key] })) : [];
          setOrders(o.sort((a, b) => b.createdAt - a.createdAt));
        });

        return () => { unsubProducts(); unsubOrders(); };
      }, [user]);

      if (!adminAuth) {
        return (
          <div className="min-h-screen flex items-center justify-center bg-gray-50">
            <div className="bg-white p-8 rounded shadow w-96 text-center">
              <h2 className="text-2xl font-bold mb-4">Admin Login</h2>
              <p className="text-sm text-gray-500 mb-4">Demo passcode: admin123</p>
              <input type="password" placeholder="Passcode" className="border p-2 w-full" onChange={(e) => { if (e.target.value === 'admin123') setAdminAuth(true); }} />
            </div>
          </div>
        );
      }

      const totalRevenue = orders.filter(o => o.status === 'Delivered').reduce((sum, o) => sum + o.total, 0);
      const pendingOrders = orders.filter(o => o.status === 'Pending').length;

      return (
        <div className="min-h-screen bg-gray-100 flex font-sans">
          <div className="w-64 bg-white border-r h-screen fixed flex flex-col">
            <div className="p-6 border-b"><h2 className="text-xl font-bold uppercase">Blaze Admin</h2></div>
            <div className="flex-1 py-4">
              <button onClick={() => setTab('dashboard')} className={`w-full text-left px-6 py-3 font-medium ${tab === 'dashboard' ? 'bg-gray-50 text-black border-r-4 border-black' : 'text-gray-500'}`}>Dashboard</button>
              <button onClick={() => setTab('products')} className={`w-full text-left px-6 py-3 font-medium ${tab === 'products' ? 'bg-gray-50 text-black border-r-4 border-black' : 'text-gray-500'}`}>Products</button>
              <button onClick={() => setTab('orders')} className={`w-full text-left px-6 py-3 font-medium ${tab === 'orders' ? 'bg-gray-50 text-black border-r-4 border-black' : 'text-gray-500'}`}>Orders {pendingOrders > 0 && <span className="bg-red-500 text-white text-[10px] px-2 py-0.5 rounded ml-2">{pendingOrders}</span>}</button>
            </div>
          </div>

          <div className="ml-64 flex-1 p-8">
            {tab === 'dashboard' && (
              <div>
                <h1 className="text-3xl font-bold mb-8">Dashboard</h1>
                <div className="grid grid-cols-3 gap-6">
                  <div className="bg-white p-6 rounded shadow">
                    <div className="text-gray-500 flex items-center mb-2"><span className="mr-2"><IconTrending /></span> Revenue (Delivered)</div>
                    <div className="text-3xl font-bold text-green-600">{formatPrice(totalRevenue)}</div>
                  </div>
                  <div className="bg-white p-6 rounded shadow">
                    <div className="text-gray-500 flex items-center mb-2"><span className="mr-2"><IconPackage /></span> Total Orders</div>
                    <div className="text-3xl font-bold">{orders.length}</div>
                  </div>
                  <div className="bg-white p-6 rounded shadow">
                    <div className="text-gray-500 flex items-center mb-2"><span className="mr-2"><IconClock /></span> Pending Action</div>
                    <div className="text-3xl font-bold text-orange-500">{pendingOrders}</div>
                  </div>
                </div>
              </div>
            )}
            {tab === 'products' && <ProductManager products={products} />}
            {tab === 'orders' && <OrderManager orders={orders} />}
          </div>
        </div>
      );
    }

    const root = ReactDOM.createRoot(document.getElementById('root'));
    root.render(<App />);
  </script>
</body>
</html>
